generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())

  attendance    Attendance[]
  notifications Notification[]
}

model School {
  id        String   @id @default(uuid())
  name      String
  district  String
  location  String
  createdAt DateTime @default(now())

  users    User[]
  students Student[]
  meals    Meal[]
  alerts   Alert[]
  menus    Menu[]
}

model Student {
  id            String @id @default(uuid())
  name          String
  class         String
  parentContact String
  schoolId      String
  school        School @relation(fields: [schoolId], references: [id])

  attendance Attendance[]
}

model Menu {
  id          String @id @default(uuid())
  schoolId    String
  school      School @relation(fields: [schoolId], references: [id])
  dayOfWeek   String
  defaultMenu String
}

model Meal {
  id        String   @id @default(uuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  date      DateTime
  menu      String
  imageUrl  String
  timestamp DateTime @default(now())
}

model Attendance {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  className String
  meal      String
  status    String
  photo     String?

  date DateTime

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([studentId, meal, date])
  @@index([date, className])
}

model Notification {
  id       String   @id @default(uuid())
  parentId String
  parent   User     @relation(fields: [parentId], references: [id])
  message  String
  date     DateTime @default(now())
}

model Alert {
  id        String   @id @default(uuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  issueType String
  date      DateTime @default(now())
}

model TodayMealPhoto {
  id          String   @id @default(uuid())
  schoolId    String
  mealType    String
  itemName    String
  photoUrl    String
  date        DateTime
  submittedBy String
  createdAt   DateTime @default(now())
}

model Contractor {
  id String @id @default(cuid())

  contractorId String @unique
  name         String

  startDate DateTime
  endDate   DateTime

  mealsProvided   String
  kitchenLocation String

  totalStudents Int
  hygieneRating String

  contactPerson String
  phone         String
  email         String
  address       String

  deliveryPercent Float
  complaintsCount Int
  feedbackRating  Float

  deliveries  Delivery[]
  complaints  Complaint[]
  inspections Inspection[]
  schools     SchoolCoverage[]

  createdAt DateTime @default(now())
}

model Delivery {
  id String @id @default(cuid())

  date DateTime

  breakfast Boolean
  lunch     Boolean
  snacks    Boolean
  dinner    Boolean

  status String

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
}

model Complaint {
  id String @id @default(cuid())

  issue  String
  status String
  date   DateTime

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
}

model Inspection {
  id String @id @default(cuid())

  date    DateTime
  officer String
  grade   String
  remarks String

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
}

model SchoolCoverage {
  id String @id @default(cuid())

  schoolId   String
  schoolName String
  students   Int

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
}

model Issue {
  id          String   @id
  issueName   String
  description String
  status      String
  date        String
  photo       String
  createdAt   DateTime @default(now())
}

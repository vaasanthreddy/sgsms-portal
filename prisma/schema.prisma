generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          String
  schoolId      String?
  createdAt     DateTime       @default(now())
  attendance    Attendance[]
  notifications Notification[]
  school        School?        @relation(fields: [schoolId], references: [id])
}

model School {
  id        String    @id @default(uuid())
  name      String
  district  String
  location  String
  createdAt DateTime  @default(now())
  alerts    Alert[]
  meals     Meal[]
  menus     Menu[]
  students  Student[]
  users     User[]
}

model Student {
  id            String       @id @default(uuid())
  name          String
  class         String
  parentContact String
  schoolId      String
  attendance    Attendance[]
  school        School       @relation(fields: [schoolId], references: [id])
}

model Menu {
  id          String @id @default(uuid())
  schoolId    String
  dayOfWeek   String
  defaultMenu String
  school      School @relation(fields: [schoolId], references: [id])
}

model Meal {
  id        String   @id @default(uuid())
  schoolId  String
  date      DateTime
  menu      String
  imageUrl  String
  timestamp DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  date      DateTime
  status    String
  userId    String?
  className String
  createdAt DateTime @default(now())
  meal      String
  photo     String?
  student   Student  @relation(fields: [studentId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@unique([studentId, meal, date])
  @@index([date, className])
}

model Notification {
  id       String   @id @default(uuid())
  parentId String
  message  String
  date     DateTime @default(now())
  parent   User     @relation(fields: [parentId], references: [id])
}

model Alert {
  id        String   @id @default(uuid())
  schoolId  String
  issueType String
  date      DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])
}

model TodayMealPhoto {
  id          String   @id @default(uuid())
  schoolId    String
  mealType    String
  itemName    String
  photoUrl    String
  date        DateTime
  submittedBy String
  createdAt   DateTime @default(now())
}

model Contractor {
  id              String           @id @default(cuid())
  contractorId    String           @unique
  name            String
  startDate       DateTime
  endDate         DateTime
  mealsProvided   String
  kitchenLocation String
  hygieneRating   String
  totalStudents   Int
  contactPerson   String
  phone           String
  email           String
  address         String
  feedbackRating  Float
  createdAt       DateTime         @default(now())
  complaintsCount Int
  deliveryPercent Float
  complaints      Complaint[]
  deliveries      Delivery[]
  inspections     Inspection[]
  schools         SchoolCoverage[]
}

model Delivery {
  id           String     @id @default(cuid())
  date         DateTime
  breakfast    Boolean
  lunch        Boolean
  snacks       Boolean
  dinner       Boolean
  status       String
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
}

model Complaint {
  id           String     @id @default(cuid())
  issue        String
  status       String
  date         DateTime
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
}

model Inspection {
  id           String     @id @default(cuid())
  date         DateTime
  officer      String
  grade        String
  remarks      String
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
}

model SchoolCoverage {
  id           String     @id @default(cuid())
  schoolId     String
  schoolName   String
  students     Int
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
}

model Issue {
  id          String   @id
  description String
  photo       String
  status      String
  createdAt   DateTime @default(now())
  date        String
  issueName   String
}
